# Copy this file to .env and fill it in. NEVER commit .env — it holds secrets.

# ---- Slack (from api.slack.com/apps — see README.md) ----------------------
# Bot User OAuth Token (OAuth & Permissions page)
SLACK_BOT_TOKEN=xoxb-...
# App-Level Token with connections:write scope (Basic Information page)
SLACK_APP_TOKEN=xapp-...

# Channel this bridge instance listens to. Use the channel ID (starts with C),
# found in channel details -> "About" -> bottom of the panel.
# Each bridge instance must have its OWN channel.
SLACK_CHANNEL_ID=

# ---- Machine / Claude Code ------------------------------------------------
# Short label for this machine, shown in !status / !help.
CLUSTER_NAME=

# Directory on this machine where Claude Code should work (your project dir).
CLAUDE_WORKDIR=

# Path to the claude binary if not on PATH for non-login shells.
CLAUDE_BIN=claude

# Permission mode: default | acceptEdits | plan | dontAsk | bypassPermissions
# acceptEdits = Claude edits files freely but still can't run arbitrary
# side-effectful commands without an allow rule. Start here.
PERMISSION_MODE=acceptEdits

# Extra flags appended to every invocation, e.g. tool allow-list:
# CLAUDE_EXTRA_ARGS=--allowedTools Read Edit Grep Glob "Bash(python *)" "Bash(git status)"
CLAUDE_EXTRA_ARGS=

# Max seconds per Claude turn before the bridge gives up.
CLAUDE_TIMEOUT_SECONDS=1800

# true = reply in a thread under your message; false = reply in the channel.
REPLY_IN_THREAD=true

# Post a short usage message to the channel whenever the bridge (re)connects.
STARTUP_MESSAGE=true

# ---- Access control (strongly recommended) --------------------------------
# Comma-separated Slack member IDs (starts with U) allowed to use the bridge.
# Find yours: your Slack profile -> "..." -> Copy member ID.
# Empty = anyone who can post in the channel can run code on your machine!
ALLOWED_USERS=
